/**
 * AWS Cloud Club - Firestore Security Rules
 *
 * CORE PHILOSOPHY
 * This ruleset facilitates a public-facing community platform for the AWS Cloud Club. 
 * It prioritizes low-friction engagement (public form submissions) while maintaining 
 * strict administrative control over club-managed content and sensitive member data.
 *
 * DATA STRUCTURE
 * All entities are organized into top-level collections for maximum scalability:
 * - /events/{eventId}: Public event information.
 * - /team/{teamMemberId}: Public core team profiles.
 * - /projects/{projectId}: Public student project showcases.
 * - /members/{memberId}: Membership applications (Public write, Admin read).
 *
 * KEY SECURITY DECISIONS
 * - Public Content: Events, Team Members, and Projects are globally readable to 
 *   encourage engagement, but write access is strictly reserved for administrators.
 * - Membership Submissions: The 'Become a Member' form uses an "Open Create" 
 *   pattern. Anyone can submit a membership application to lower the barrier 
 *   to entry, but once submitted, only administrators can view or manage the data.
 * - Relational Integrity: In the 'members' collection, we enforce that the 
 *   internal 'id' field matches the Firestore Document ID during creation to 
 *   ensure data consistency for the Trigger Email extension.
 * - Administrator Authorization: Administrative access is governed by a 
 *   centralized 'roles_admin' collection check.
 *
 * DENORMALIZATION FOR AUTHORIZATION
 * - All documents include their own unique identifier ('id') to allow for 
 *   fast, non-recursive validation of path consistency without additional 
 *   database lookups.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** 
     * @description Basic check to see if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Verifies if the authenticated user has an entry in the admin roles collection.
     * This relies on the pattern defined in the IR reasoning.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** 
     * @description Ensures a document exists before performing state-changing operations.
     */
    function existsInDb() {
      return resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the 'events' collection. Publicly viewable club events.
     * @path /events/{eventId}
     * @allow get, list: if true; (Public viewing)
     * @deny create, update, delete: if !isAdmin(); (Only admins manage content)
     * @principle Public Read with Restricted Writes.
     */
    match /events/{eventId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && existsInDb();
    }

    /**
     * @description Rules for the 'team' collection. Profiles of the core club team.
     * @path /team/{teamMemberId}
     * @allow get, list: if true; (Publicly accessible profiles)
     * @deny write: if !isAdmin(); (Protects team profiles from tampering)
     * @principle Administrative control for club-branded content.
     */
    match /team/{teamMemberId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && existsInDb();
    }

    /**
     * @description Rules for the 'projects' collection. Showcasing student work.
     * @path /projects/{projectId}
     * @allow get, list: if true; (Maximized visibility for student projects)
     * @deny create: if !isAdmin(); (Moderated project listing)
     * @principle Independent authorization for top-level resources.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && existsInDb();
    }

    /**
     * @description Rules for 'members' collection. Handles form submissions from 'Become a Member'.
     * @path /members/{memberId}
     * @allow create: if request.resource.data.id == memberId; (Public submission allowed)
     * @allow get, list: if isAdmin(); (Privacy-first: only admins view member details)
     * @deny update, delete: if !isAdmin(); (Prevents users from altering records after submission)
     * @principle Relational integrity for 'id' and restricted access to PII.
     */
    match /members/{memberId} {
      // Create is public to allow anonymous or newly registered form submissions.
      // We strictly enforce that the internal 'id' matches the document ID.
      allow create: if request.resource.data.id == memberId;
      
      // Reading sensitive member info is restricted to verified administrators.
      allow get, list: if isAdmin();
      
      // Modifications and removals are restricted to admins.
      allow update, delete: if isAdmin() && existsInDb();
    }
  }
}