
{
  "entities": {
    "Event": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Event",
      "type": "object",
      "description": "Represents an event organized by the AWS Cloud Club, detailing its schedule and content.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Event entity."
        },
        "title": {
          "type": "string",
          "description": "The title of the event."
        },
        "date": {
          "type": "string",
          "description": "The date and time when the event is scheduled.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the event's agenda and goals."
        }
      },
      "required": [
        "id",
        "title",
        "date",
        "description"
      ]
    },
    "TeamMember": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TeamMember",
      "type": "object",
      "description": "Represents a member of the AWS Cloud Club's core team, detailing their role and profile.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the TeamMember entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the team member."
        },
        "role": {
          "type": "string",
          "description": "The role or position of the team member within the club (e.g., Captain, Technical Lead)."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL to the profile image of the team member.",
          "format": "uri"
        },
        "linkedin": {
          "type": "string",
          "description": "LinkedIn profile URL.",
          "format": "uri"
        },
        "type": {
          "type": "string",
          "enum": [
            "student",
            "faculty"
          ],
          "description": "The type of team member (student lead or faculty advisor)."
        }
      },
      "required": [
        "name",
        "role",
        "type"
      ]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a student project showcased by the AWS Cloud Club, including its details and tech stack.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Project entity."
        },
        "title": {
          "type": "string",
          "description": "The title of the project."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the project, its purpose, and outcome."
        },
        "techStack": {
          "type": "array",
          "description": "A list of technologies and AWS services used in the project.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "techStack"
      ]
    },
    "Registration": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Registration",
      "type": "object",
      "description": "Represents a student registration for the AWS Cloud Club.",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "The full name of the student."
        },
        "collegeEmail": {
          "type": "string",
          "format": "email",
          "description": "The official college email address."
        },
        "usn": {
          "type": "string",
          "description": "University Seat Number or College ID."
        },
        "primaryInterest": {
          "type": "string",
          "enum": [
            "Cloud Architecture",
            "Serverless Computing",
            "AI & Machine Learning (Generative AI)",
            "DevOps & CI/CD",
            "Cloud Security & Compliance",
            "Big Data & Analytics",
            "Internet of Things (IoT)",
            "Full Stack Development (AWS Amplify)",
            "Database Engineering (SQL/NoSQL)",
            "Networking & Content Delivery",
            "Containers & Kubernetes (ECS/EKS)",
            "Cloud Financial Management (FinOps)",
            "Site Reliability Engineering (SRE)",
            "High Performance Computing (HPC)",
            "Hybrid Cloud Solutions"
          ],
          "description": "The student's primary area of interest in technology."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the registration was submitted."
        }
      },
      "required": [
        "fullName",
        "collegeEmail",
        "usn",
        "primaryInterest"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/events/{eventId}",
        "definition": {
          "entityName": "Event",
          "schema": {
            "$ref": "#/backend/entities/Event"
          },
          "description": "Stores details of events organized by the AWS Cloud Club."
        }
      },
      {
        "path": "/team/{teamMemberId}",
        "definition": {
          "entityName": "TeamMember",
          "schema": {
            "$ref": "#/backend/entities/TeamMember"
          },
          "description": "Contains profiles of core team members."
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/backend/entities/Project"
          },
          "description": "Showcases student projects."
        }
      },
      {
        "path": "/club_members/{memberId}",
        "definition": {
          "entityName": "Registration",
          "schema": {
            "$ref": "#/backend/entities/Registration"
          },
          "description": "Stores new student registrations for the club membership."
        }
      }
    ]
  }
}
